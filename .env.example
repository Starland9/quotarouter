# FreeRouter Configuration
# Copy this file to .env and fill in your API keys

# Cerebras API
# Get key at: https://www.cerebras.ai/
# 1M tokens/day free tier
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Groq API
# Get key at: https://console.groq.com/
# 500K tokens/day free tier
GROQ_API_KEY=your_groq_api_key_here

# Google AI Studio
# Get key at: https://aistudio.google.com/
# 480K tokens/day free tier
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Mistral AI
# Get key at: https://console.mistral.ai/
# 1B tokens/month (~33M/day) free tier
MISTRAL_API_KEY=your_mistral_api_key_here

# OpenRouter
# Get key at: https://openrouter.ai/
# 200K tokens/day free tier
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Alibaba DashScope
# Get key at: https://dashscope.aliyun.com/
# OpenAI-compatible API (qwen models)
ALIBABA_API_KEY=your_alibaba_api_key_here
